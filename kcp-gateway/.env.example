# KCP Gateway 환경변수 설정
# 이 파일을 .env로 복사하고 실제 값으로 수정한 후 사용하세요.
# 절대로 .env 파일을 Git에 커밋하지 마세요.

# 서버 설정
PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# 데이터베이스
DATABASE_URL=postgresql://kcp:kcppassword@localhost:5432/kcp?sslmode=disable

# JWT 인증
JWT_SECRET=your-secret-key-change-this
JWT_EXPIRY=15m

# OpenStack 연동 (Epoxy 2025.1)
OPENSTACK_AUTH_URL=https://keystone.example.com:5000/v3
OPENSTACK_USERNAME=admin
OPENSTACK_PASSWORD=secret
OPENSTACK_PROJECT_ID=your-project-id
OPENSTACK_DOMAIN_ID=default

# TLS 설정 (선택)
TLS_ENABLED=false
TLS_CERT_PATH=
TLS_KEY_PATH=
